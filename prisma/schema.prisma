// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ConversationType {
  DIRECT
  GROUP
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  displayName  String
  passwordHash String
  bio          String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sentMessages   Message[]
  participations Participation[]
  blockedUsers   Block[]         @relation("UserBlocks")
  blockedByUsers Block[]         @relation("UserBlockedBy")
}

model Conversation {
  id             String           @id @default(cuid())
  type           ConversationType
  title          String?
  participantKey String?          @unique
  lastMessageId  String?          @unique
  lastMessage    Message?         @relation("LastMessage", fields: [lastMessageId], references: [id])
  lastMessageAt  DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  participants Participation[]
  messages     Message[]       @relation("ConversationMessages")

  @@index([lastMessageAt])
}

model Participation {
  userId         String
  conversationId String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@id([userId, conversationId])
  @@index([conversationId])
}

model Message {
  id             String   @id @default(cuid())
  senderId       String
  conversationId String
  content        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sender               User          @relation(fields: [senderId], references: [id])
  conversation         Conversation  @relation("ConversationMessages", fields: [conversationId], references: [id])
  latestInConversation Conversation? @relation("LastMessage")

  @@index([conversationId])
}

model Block {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("UserBlocks", fields: [blockerId], references: [id])
  blocked User @relation("UserBlockedBy", fields: [blockedId], references: [id])

  @@id([blockerId, blockedId])
}
